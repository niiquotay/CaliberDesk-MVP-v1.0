{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/test",
      "destination": "/api/test.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index_minimal.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
